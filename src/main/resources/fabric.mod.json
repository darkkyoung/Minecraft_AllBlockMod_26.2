{
	"schemaVersion": 1,
	"id": "allblocks",
	"version": "${version}",
	"name": "All Blocks Challenge",
	"description": "A survival challenge mod where players collect blocks, fill the block encyclopedia, compete through rankings, and trigger challenge events.",
	"authors": [
		"darkkyoung"
	],
	"contact": {
		"sources": "https://github.com/darkkyoung/Minecraft_AllBlockMod_26.2"
	},
	"license": "All Rights Reserved",
	"icon": "assets/allblocks/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
          "com.darkk0729.allblocks.AllBlocksMod"
		],
		"client": [
          "com.darkk0729.allblocks.client.AllBlocksClient"
		]
	},
	"mixins": [
		"allblocks.mixins.json",
		{
			"config": "allblocks.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}